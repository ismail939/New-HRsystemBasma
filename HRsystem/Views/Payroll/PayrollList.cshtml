@model List<HRsystem.ViewModels.PayrollListViewModel>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "كشوفات الرواتب";
}

<h2 class="fs-3 text-center p-4 m-2 text-color3 shadow-lg">كشوفات الرواتب</h2>

<div class="flex justify-center mb-4">
    <a href="/payroll/generate" class="cursor-pointer mx-1 col-button-dark px-4 py-2 rounded">
        إنشاء كشف راتب جديد
    </a>
</div>

<div id="tableResponsive" class="tableContainer">
    @if (Model.Count == 0)
    {
        <div class="shadow-lg flex justify-center items-center flex-col p-3">
            <div class="text-center p-4 m-2 text-[40px]">لا توجد كشوفات رواتب</div>
            <img src="~/images/noEmp2.png" style="width:200px;height:200px" />
        </div>
    }
    else
    {
        <table class="table-base min-w-full border-separate border-spacing-0">
            <thead class="table-dark col-table-header sticky top-0 z-10">
                <tr>
                    <th>الشهر</th>
                    <th>السنة</th>
                    <th>الحالة</th>
                    <th>عدد الموظفين</th>
                    <th>تاريخ الإنشاء</th>
                    <th>تم بواسطة</th>
                    <th>ملاحظات</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var payroll in Model)
                {
                    var statusClass = payroll.Status switch
                    {
                        "Draft" => "text-yellow-600",
                        "Reviewed" => "text-blue-600",
                        "Approved" => "text-green-600",
                        "Locked" => "text-red-600",
                        _ => ""
                    };
                    var statusText = payroll.Status switch
                    {
                        "Draft" => "مسودة",
                        "Reviewed" => "مراجع",
                        "Approved" => "معتمد",
                        "Locked" => "مقفل",
                        _ => payroll.Status
                    };

                    <tr>
                        <td>@payroll.MonthName</td>
                        <td>@payroll.Year</td>
                        <td class="font-semibold @statusClass">@statusText</td>
                        <td>@payroll.EmployeeCount</td>
                        <td>@payroll.GeneratedDate.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@payroll.GeneratedBy</td>
                        <td>@(payroll.Notes ?? "-")</td>
                        <td>
                            <a href="/payroll/details/@payroll.Id" class="col-button-dark text-[11px] rounded px-3 py-1">
                                التفاصيل
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>