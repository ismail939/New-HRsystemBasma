
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "البصمة";
}
<h2 class="fs-3 text-center p-4 m-2 text-color3 shadow-lg">إدارة البصمة</h2>



<div class="flex flex-row flex-start gap-2 mb-1 relative">

    <input type="date" id="datePicker" placeholder="تاريخ اليوم"
        class="border border-gray-300 rounded-md py-2 focus:ring focus:ring-color2 focus:outline-none text-center text-color5" />
    <div x-data="{
        showSearch: false,
        toggleSearch() {
            this.showSearch = !this.showSearch;

            if (this.showSearch) {
                // Focus the input after it appears
                this.$nextTick(() => document.getElementById('searchInput')?.focus());
            } else {
                // Clear and show all employees when refresh is clicked
                const input = document.getElementById('searchInput');
                if (input) input.value = '';
                showBasmaListForDay();
            }
        }
    }" class="flex items-center gap-2">
        <!-- Search / Refresh Button -->
        <button @@click="toggleSearch"
            class="p-2 rounded-full bg-[#404E3B] text-white hover:bg-[#A7B89A] transition-all duration-300">
            <i :class="showSearch ? 'bi-arrow-clockwise' : 'bi-search'" class="text-lg"></i>
        </button>

        <!-- Search input -->
        <template x-if="showSearch">
            <div class="flex items-center gap-2 animate-fade-in">
                <input id="searchInput" type="text" placeholder="ابحث عن موظف..." oninput="searchForEmployee()"
                    class="border border-gray-300 rounded-md px-5 py-2 focus:ring focus:ring-[#BAC8B1] focus:outline-none text-sm" />
            </div>
        </template>
    </div>
    <div class="absolute left-2 flex gap-2 flex-row">
        <a class="col-button-dark" onclick="downloadDailyReport()">طباعة التقرير</a>
    <button class="col-button-light" onclick="saveNotes()">حفظ الملاحظات</button>
    </div>
</div>


<div id="tableResponsive" class="tableContainer ">
    <table class="table-base min-w-full border-separate border-spacing-0" id="employeesTable">
        <thead class="table-dark col-table-header sticky top-0 z-10">
            <tr>
                <th>الاسم</th>
                <th>وقت الحضور</th>
                <th>وقت الانصراف</th>
                <th>عدد ساعات العمل</th>
                <th>التأخير</th>
                <th>الخروج المبكر</th>
                <th>العمل الإضافي</th>
                <th>الحالة</th>
                <th>ملاحظات</th>
            </tr>
        </thead>
        <tbody id="employeesBody" class="mt-3">
        </tbody>
    </table>
    <div class="hidden" id="noDataMessage">
        <p class="text-center text-[40px] text-gray-500 mt-4">لا توجد بيانات لعرضها.</p>
    </div>
</div>

<!-- SMALL DROPDOWN POPUP -->
<div id="showBasmaModal" class="hidden fixed inset-0 bg-black/30 z-50
              items-center justify-center">

    <div id="" class="col-modal relative p-6 rounded-2xl shadow-xl !h-1/4 !w-1/2 text-center">
        <h3 class="text-lg font-bold mb-3">هل انت متأكد من إعداد الشيفتات لهذا اليوم؟</h3>

        
        <div class="flex flex-row gap-2 justify-center items-center w-full mt-2">
            <button type="button" onclick="proceedShowingBasma()"
                class="py-4 w-full px-4 rounded-lg col-button-dark">
                نعم
            </button>
            <button type="button" onclick="goToEmployees()"
                class="py-4 px-4 w-full rounded-lg col-button-dark">
                لا
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Basma/BasmaTable.js">
    </script>
}