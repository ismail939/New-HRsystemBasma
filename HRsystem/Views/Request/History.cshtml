@model List<ManageRequestViewModel>
@{
    ViewData["Title"] = "سجل الطلبات";
}

<div class="max-w-5xl mx-auto p-4 md:p-6" dir="rtl">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl md:text-3xl font-bold text-gray-800">سجل الطلبات</h1>
            <p class="text-sm text-gray-500 mt-1">جميع طلبات الإجازة السابقة</p>
        </div>
        <a href="/requests/pending" 
           class="px-4 py-2 bg-blue-600 text-white text-sm rounded-xl hover:bg-blue-700 transition-all duration-200 flex items-center gap-2">
            <i class="bi bi-inbox"></i>
            الطلبات المعلقة
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="space-y-3">
            @foreach (var request in Model)
            {
                <div class="bg-white rounded-2xl shadow-sm hover:shadow-md transition-all duration-300 p-5 border border-gray-100">
                    <div class="flex items-start gap-4">
                        <!-- Status Icon -->
                        <div class="flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center text-xl
                            @(request.Status == RequestStatus.Approved ? "bg-green-100 text-green-600" :
                              request.Status == RequestStatus.Rejected ? "bg-red-100 text-red-600" :
                              "bg-yellow-100 text-yellow-600")">
                            <i class="@(request.Status == RequestStatus.Approved ? "bi bi-check-circle-fill" :
                                       request.Status == RequestStatus.Rejected ? "bi bi-x-circle-fill" :
                                       "bi bi-hourglass-split")"></i>
                        </div>

                        <!-- Request Info -->
                        <div class="flex-1 min-w-0">
                            <div class="flex items-start justify-between gap-2">
                                <div>
                                    <h3 class="font-semibold text-gray-900">@request.EmployeeName</h3>
                                    <p class="text-sm text-gray-500">@request.RequestTypeName - @request.LeaveTypeName</p>
                                    @if (!string.IsNullOrEmpty(request.Reason))
                                    {
                                        <p class="text-sm text-gray-600 mt-1">@request.Reason</p>
                                    }
                                </div>
                                <span class="flex-shrink-0 px-3 py-1 rounded-full text-xs font-semibold
                                    @(request.Status == RequestStatus.Approved ? "bg-green-100 text-green-800" :
                                      request.Status == RequestStatus.Rejected ? "bg-red-100 text-red-800" :
                                      "bg-yellow-100 text-yellow-800")">
                                    @(request.Status == RequestStatus.Approved ? "تمت الموافقة" :
                                      request.Status == RequestStatus.Rejected ? "مرفوض" :
                                      "قيد الانتظار")
                                </span>
                            </div>
                            <p class="text-xs text-gray-400 mt-2">
                                <i class="bi bi-clock ml-1"></i>
                                @request.CreatedAt.ToString("yyyy/MM/dd HH:mm")
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="text-center py-16 bg-white rounded-2xl shadow-sm border border-gray-100">
            <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-gray-100 flex items-center justify-center">
                <i class="bi bi-journal-text text-4xl text-gray-400"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-600 mb-1">لا توجد طلبات</h3>
            <p class="text-sm text-gray-400">لم يتم تقديم أي طلبات بعد</p>
        </div>
    }
</div>