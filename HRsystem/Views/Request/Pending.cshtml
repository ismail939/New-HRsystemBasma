@model List<ManageRequestViewModel>
@{
    ViewData["Title"] = "الطلبات المعلقة";
}

<div class="max-w-5xl mx-auto p-4 md:p-6" dir="rtl">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl md:text-3xl font-bold" style="color: #404E3B;">الطلبات المعلقة</h1>
            <p class="text-sm mt-1" style="color: #6C8480;">طلبات الإجازة التي تنتظر الموافقة</p>
        </div>
        <a href="/requests/history" 
           class="px-4 py-2 text-sm rounded-xl transition-all duration-200 flex items-center gap-2" style="background-color: #BAC8B1; color: #404E3B; hover:background-color: #7B9669;">
            <i class="bi bi-clock-history"></i>
            السجل
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 p-4 rounded-xl text-sm flex items-center gap-2" style="background-color: #BAC8B1; color: #404E3B;">
            <i class="bi bi-check-circle-fill" style="color: #7B9669;"></i>
            @TempData["Success"]
        </div>
    }

    @if (Model.Any())
    {
        <div class="space-y-4">
            @foreach (var request in Model)
            {
                <div class="bg-white rounded-2xl shadow-sm hover:shadow-md transition-all duration-300 p-5 border border-gray-100">
                    <div class="flex items-start gap-4">
                        <!-- Status Icon -->
                        <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-yellow-100 flex items-center justify-center text-xl">
                            <i class="bi bi-hourglass-split text-yellow-600"></i>
                        </div>

                        <!-- Request Info -->
                        <div class="flex-1 min-w-0">
                            <div class="flex items-start justify-between gap-2">
                                <div>
                                    <h3 class="font-semibold text-gray-900">@request.EmployeeName</h3>
                                    <p class="text-sm text-gray-500">@request.RequestTypeName - @request.LeaveTypeName</p>
                                    @if (!string.IsNullOrEmpty(request.Reason))
                                    {
                                        <p class="text-sm text-gray-600 mt-2 bg-gray-50 p-2 rounded-lg">@request.Reason</p>
                                    }
                                </div>
                                <span class="flex-shrink-0 px-3 py-1 rounded-full text-xs font-semibold bg-yellow-100 text-yellow-800">
                                    بانتظار الموافقة
                                </span>
                            </div>
                            <p class="text-xs text-gray-400 mt-2">
                                <i class="bi bi-clock ml-1"></i>
                                @request.CreatedAt.ToString("yyyy/MM/dd HH:mm")
                            </p>

                            <!-- Always Visible Action Buttons -->
                            <div class="mt-4 flex items-center gap-2">
                                <button onclick="showResponseForm(@request.RequestId)"
                                        class="px-4 py-2 bg-green-600 text-white text-sm rounded-xl hover:bg-green-700 transition-all duration-200 flex items-center gap-1 shadow-sm">
                                    <i class="bi bi-check-circle"></i>
                                    موافقة
                                </button>
                                <button onclick="showRejectForm(@request.RequestId)"
                                        class="px-4 py-2 bg-red-600 text-white text-sm rounded-xl hover:bg-red-700 transition-all duration-200 flex items-center gap-1 shadow-sm">
                                    <i class="bi bi-x-circle"></i>
                                    رفض
                                </button>
                            </div>

                            <!-- Response Form (hidden by default) -->
                            <div id="responseForm-@request.RequestId" class="hidden mt-4 p-4 bg-gray-50 rounded-xl border border-gray-200">
                                <form method="post" action="/requests/approve/@request.RequestId" class="space-y-3">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="RequestId" value="@request.RequestId" />
                                    <div>
                                        <label class="block text-sm font-semibold text-gray-700 mb-1">رسالة الرد (اختياري)</label>
                                        <textarea name="ResponseMessage" rows="2" id="responseMsg-@request.RequestId"
                                                  class="w-full px-3 py-2 rounded-lg border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition-all duration-200 resize-none"
                                                  placeholder="اكتب ملاحظاتك..."></textarea>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <button type="submit" class="px-4 py-2 bg-green-600 text-white text-sm rounded-xl hover:bg-green-700 transition-all duration-200">
                                            <i class="bi bi-check-circle"></i>
                                            تأكيد الموافقة
                                        </button>
                                        <button type="button" onclick="hideResponseForm(@request.RequestId)"
                                                class="px-4 py-2 bg-gray-200 text-gray-700 text-sm rounded-xl hover:bg-gray-300 transition-all duration-200">
                                            إلغاء
                                        </button>
                                    </div>
                                </form>
                            </div>

                            <!-- Reject Form (hidden by default) -->
                            <div id="rejectForm-@request.RequestId" class="hidden mt-4 p-4 bg-red-50 rounded-xl border border-red-200">
                                <form method="post" action="/requests/reject/@request.RequestId" class="space-y-3">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="RequestId" value="@request.RequestId" />
                                    <div>
                                        <label class="block text-sm font-semibold text-gray-700 mb-1">سبب الرفض (اختياري)</label>
                                        <textarea name="ResponseMessage" rows="2" id="rejectMsg-@request.RequestId"
                                                  class="w-full px-3 py-2 rounded-lg border border-red-300 focus:border-red-500 focus:ring-2 focus:ring-red-200 transition-all duration-200 resize-none"
                                                  placeholder="اذكر سبب الرفض..."></textarea>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <button type="submit" class="px-4 py-2 bg-red-600 text-white text-sm rounded-xl hover:bg-red-700 transition-all duration-200">
                                            <i class="bi bi-x-circle"></i>
                                            تأكيد الرفض
                                        </button>
                                        <button type="button" onclick="hideRejectForm(@request.RequestId)"
                                                class="px-4 py-2 bg-gray-200 text-gray-700 text-sm rounded-xl hover:bg-gray-300 transition-all duration-200">
                                            إلغاء
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="text-center py-16 bg-white rounded-2xl shadow-sm border border-gray-100">
            <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-green-100 flex items-center justify-center">
                <i class="bi bi-check2-all text-4xl text-green-500"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-600 mb-1">لا توجد طلبات معلقة</h3>
            <p class="text-sm text-gray-400">جميع الطلبات تمت معالجتها</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        function showResponseForm(id) {
            document.getElementById('responseForm-' + id).classList.remove('hidden');
            document.getElementById('rejectForm-' + id).classList.add('hidden');
        }
        function hideResponseForm(id) {
            document.getElementById('responseForm-' + id).classList.add('hidden');
        }
        function showRejectForm(id) {
            document.getElementById('rejectForm-' + id).classList.remove('hidden');
            document.getElementById('responseForm-' + id).classList.add('hidden');
        }
        function hideRejectForm(id) {
            document.getElementById('rejectForm-' + id).classList.add('hidden');
        }
    </script>
}