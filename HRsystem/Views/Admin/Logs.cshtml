@model IEnumerable<HRLog>

<h2 class="fs-3 text-center p-4 m-2 text-color3 shadow-lg">سجل النظام</h2>

<div class="flex flex-col w-full">
    <div class="mx-4">
        <div id="tableResponsive" class="tableContainer">
            @if (Model.Count() == 0)
            {
                <div class="shadow-lg w-full my-3 h-1/2 flex justify-center items-center">
                    <p class="fs-6 text-color3">لا توجد سجلات بعد</p>
                </div>
            }
            else
            {
                <table dir="ltr" class="table-base min-w-full border-separate border-spacing-0" id="logsTable">
                    <thead class="table-dark listEmpTableThead col-table-header sticky top-0 z-10">
                        <tr>
                            <th>Time</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="employeesBody" class="listEmpTableTbody mt-3">
                        @foreach (var log in Model)
                        {
                            <tr class="snap-start">
                                <td>@log.CreatedAt</td>
                                <td>@log.Action</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>