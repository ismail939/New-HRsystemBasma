@model IEnumerable<HRsystem.Models.User>
<div id="tableResponsive" class="tableContainer ">
    @if (Model.Count() == 0)
    {
        <div class="shadow-lg flex justify-center items-center flex-col p-3">
            <div id="noDataDiv" class="text-center  p-4 m-2 text-[40px]">No users</div>
            <img src="~/images/noEmp2.png" style="width:200px;height:200px" />
        </div>
    }
    else
    {
        <table class="table-base min-w-full border-separate border-spacing-0" id="usersTable">
            <thead class="table-dark listEmpTableThead col-table-header sticky top-0 z-10">
                <tr>
                    <th>اسم المستخدم</th>
                    <th>كلمة المرور</th>
                    <th>الدور</th>
                    <th>تعديل</th>
                </tr>
            </thead>
            <tbody id="usersBody" class="listEmpTableTbody mt-3">
                @foreach (var user in Model)
                {
                    <tr id="row-@user.Id" class="snap-start">
                        <td>@user.Username</td>
                        <td>@user.Password</td>
                        <td>@user.Role</td>
                        <td>
                            <button class="col-button-dark text-[19px] rounded" onclick="openEditUserModal('@user.Id')">
                                تعديل
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>





<!-- Modal Background -->
<div id="editModal" class="fixed inset-0 bg-black bg-opacity-50 hidden justify-center items-center z-50
    transition-all duration-100  ">
    <!-- Modal Box -->
    <div class="col-modal !w-1/3 !h-1/2 p-6 relative overflow-y-auto" dir="rtl">
        <button onclick="closeModal()" class="absolute top-2 left-2 text-[25px]">
            <i class="bi bi-x-square-fill"></i>
        </button>

        <div id="tab-content-info">
            <h2 class="text-2xl font-semibold mb-4 text-blue-700 text-center">تعديل بيانات المستخدم</h2>
            <form id="userform" asp-action="EditUser" method="post" class="flex flex-col gap-2 w-full h-full">

                <input type="hidden" name="Id" />
                <div>
                    <label class="block text-sm font-medium text-gray-700">اسم المستخدم</label>
                    <input type="text" name="Username"
                           class="mt-1 w-full border rounded p-2 focus:outline-none focus:ring focus:ring-[#7B9669]" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700">كلمة المرور</label>
                    <input type="text" name="Password"
                           class="mt-1 w-full border rounded p-2 focus:outline-none focus:ring focus:ring-[#7B9669]" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700">الدور</label>
                    <input name="Role"
                           class="mt-1 w-full border rounded p-2 focus:outline-none focus:ring focus:ring-[#7B9669]"></input>
                </div>



                <!-- Submit Button -->
                <div class="col-span-3 text-center mt-4">
                    <button type="submit" class=" px-8 py-2 rounded col-button-dark">
                        💾 حفظ
                    </button>
                </div>

            </form>
        </div>

    </div>
</div>


@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            let users = @Html.Raw(Json.Serialize(Model));
            console.log(users)
            window.openEditUserModal = function (id) {
                console.log(typeof(id))
                let user = users.find(d => d.Id === Number(id));
                console.log(user);
                document.querySelector("#userform [name='Id']").value = user.Id;
                document.querySelector("#userform [name='Username']").value = user.Username;
                document.querySelector("#userform [name='Password']").value = user.Password;
                document.querySelector("#userform [name='Role']").value = user.Role;
                showDivFlex("editModal");
            }
            window.closeEditUserModal = function () {
                hideDivFlex("editModal");
            }
            document.getElementById("editModal").addEventListener("click", function (e) {
                if (e.target == this) {
                    closeModal();
                }
            })
        })
    </script>
}