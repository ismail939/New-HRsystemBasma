@model IEnumerable<DepartmentViewModel>

<h2 class="fs-3 text-center p-4 m-2 text-color3 shadow-lg">إدارة الأقسام</h2>

<div class="flex flex-col w-full">
    <div class="mx-4">
        <a href="/createDepartment" class="col-button-dark px-4 py-2 rounded inline-block">
            اضافة قسم
        </a>
    </div>
    <div class="mt-4 mx-4">
        <div id="tableResponsive" class="tableContainer">
            @if (Model.Count() == 0)
            {
                <div class="shadow-lg w-full my-3 h-1/2 flex justify-center items-center">
                    لا يوجد اقسام
                </div>
            }
            else
            {
                <table class="table-base min-w-full border-separate border-spacing-0" id="departmentsTable">
                    <thead class="table-dark listEmpTableThead col-table-header sticky top-0 z-10">
                        <tr>
                            <th>الاسم</th>
                            <th>الكود</th>
                            <th>القسم العام</th>
                            <th>مدير القسم</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="employeesBody" class="listEmpTableTbody mt-3">
                        @foreach (var department in Model)
                        {
                            <tr id="row-@department.Id" class="snap-start">
                                <td>@department.Name</td>
                                <td>@department.Code</td>
                                <td>@department.ParentDepartmentName</td>
                                <td>@department.ManagerName</td>
                                <td>
                                    <button onclick="openModal(@department.Id)" class="col-button-dark  text-[19px] rounded">
                                        تعديل
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>


<!-- Modal Background -->
<div id="editModal" class="fixed inset-0 bg-black bg-opacity-50 hidden justify-center items-center z-50
    transition-all duration-100  ">
    <!-- Modal Box -->
    <div class="col-modal !w-1/3  p-6 relative overflow-y-auto" dir="rtl">
        <button onclick="closeModal()" class="absolute top-2 left-2 text-[25px]">
            <i class="bi bi-x-square-fill"></i>
        </button>

        <div id="tab-content-info">
            <h2 class="text-2xl font-semibold mb-4 text-blue-700 text-center">تعديل بيانات القسم</h2>
            <form id="departmentForm" asp-action="EditDepartment" method="post"
                  class="flex flex-col gap-2 w-full h-full">

                <input type="hidden" name="Id" />
                <div>
                    <label class="block text-sm font-medium text-gray-700">اسم القسم</label>
                    <input type="text" name="Name"
                           class="mt-1 w-full border rounded p-2 focus:outline-none focus:ring focus:ring-[#7B9669]" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700">الكود</label>
                    <input type="text" name="Code"
                           class="mt-1 w-full border rounded p-2 focus:outline-none focus:ring focus:ring-[#7B9669]" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700">الوصف</label>
                    <textarea name="Description"
                              class="mt-1 w-full border rounded p-2 focus:outline-none focus:ring focus:ring-[#7B9669]"></textarea>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700">القسم العام</label>
                    <select id="departmentIdSelect" name="parentDepartmentId"
                            class="mt-1 w-full border border-color3 rounded p-2 focus:outline-none focus:ring focus:ring-color3">

                    </select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700">مدير القسم</label>
                    <select name="managerId" id="managerIdSelect"
                            class="mt-1 w-full border border-color3 rounded p-2 focus:outline-none focus:ring focus:ring-color3">
                    </select>
                </div>

                <!-- Submit Button -->
                <div class="col-span-3 text-center mt-4">
                    <button type="submit" class=" px-8 py-2 rounded col-button-dark">
                        💾 حفظ التعديلات
                    </button>
                </div>

            </form>
        </div>

    </div>
</div>


@section Scripts {
    <script>
            document.addEventListener("DOMContentLoaded", function () {
                let departments = @Html.Raw(Json.Serialize(Model));
                const editModal = document.getElementById("editModal");
                function closeModal() {
                    editModal.classList.add("hidden");
                }
                function openModal(id) {
                    console.log(id + "🟡");
                    console.log(departments);
                    let department = departments.find(d => d.Id === id);
                    document.querySelector("#departmentForm [name='Id']").value = department.Id;
                    document.querySelector("#departmentForm [name='Name']").value = department.Name;
                    document.querySelector("#departmentForm [name='Code']").value = department.Code;
                    document.querySelector("#departmentForm [name='Description']").value = department.Description;
                        // Populate parent department select
                    let parentSelect = document.getElementById("departmentIdSelect");
                    parentSelect.innerHTML = '<option value="">بدون قسم عام</option>';

                    departments.forEach(d => {
                        if (d.Id !== department.Id) {
                            parentSelect.innerHTML += `<option value="${d.Id}">${d.Name}</option>`;
                        }
                    });
                    if (department.ParentDepartmentId != undefined) {
                        parentSelect.value = String(department.ParentDepartmentId);
                    }
                        // Populate manager select
                    let managerSelect = document.getElementById("managerIdSelect");
                    managerSelect.innerHTML = '<option value="">بدون مدير</option>';
                    fetch('/Admin/GetDepartmentEmployees?departmentId=' + department.Id)
                        .then(response => response.json())
                        .then(employees => {
                            console.log(employees);
                            employees.forEach(emp => {
                                managerSelect.innerHTML += `<option value="${emp.Id}">${emp.Name}</option>`;
                            });
                            if (department.ManagerId != undefined) {
                                managerSelect.value = String(department.ManagerId);
                            }
                        })
                        .catch(error => console.error('Error fetching employees:', error));
                    editModal.classList.remove("hidden");
                    editModal.classList.add("flex");
                }
                window.closeModal = closeModal;
                window.openModal = openModal;
                editModal.addEventListener('click', function (e) {
                if (e.target === this) closeModal();
                });

            })
    </script>
}