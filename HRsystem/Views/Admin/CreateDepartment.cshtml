@model DepartmentPostRequest
<a href="/admin/dashboard/departments" class="col-button-dark">العودة</a>
<div class="flex flex-col justify-center items-center">

<h1 class="fs-1 mb-3">إضافة قسم</h1>
<form asp-action="Create" asp-controller="Admin" method="post"  class="w-2/3 flex justify-center items-center flex-col  border-2 border-black rounded p-2 ">
@Html.AntiForgeryToken()
    <div class="form-group w-full">
        <label asp-for="Name">الاسم</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group w-full">
        <label asp-for="Code">الكود</label>
        <input asp-for="Code" class="form-control" />
    </div>

    <div class="form-group w-full">
        <label asp-for="Description">وصف</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>

    <div class="form-group w-full">
        <label asp-for="ParentDepartmentId"></label>
        <select asp-for="ParentDepartmentId" 
                asp-items="Model.Departments" 
                class="form-control">
            <option value="">-- None --</option>
        </select>
    </div>

    <div class="form-group w-full">
        <label asp-for="ManagerId"></label>
        <select asp-for="ManagerId" 
                asp-items="Model.Managers" 
                class="form-control">
            <option value="">-- Select Manager --</option>
        </select>
    </div>

    <button type="submit" class="col-button-light m-3 ">إضافة</button>


</form>
</div>