@model List<LeaveRequestListViewModel>
@{
    ViewData["Title"] = "طلباتي";
    Layout = "_EmployeeLayout";
}

<div class="max-w-4xl mx-auto p-4 md:p-6" dir="rtl">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl md:text-3xl font-bold text-gray-800">طلبات الإجازة</h1>
            <p class="text-sm text-gray-500 mt-1">جميع طلبات الإجازة الخاصة بك</p>
        </div>
        <a href="/employee-dashboard/request-vacation" 
           class="px-4 py-2 bg-blue-600 text-white text-sm rounded-xl hover:bg-blue-700 transition-all duration-200 shadow-md hover:shadow-lg flex items-center gap-2">
            <i class="bi bi-plus-circle"></i>
            طلب إجازة جديد
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 p-4 bg-green-50 border border-green-200 rounded-xl text-green-700 text-sm flex items-center gap-2">
            <i class="bi bi-check-circle-fill text-green-500"></i>
            @TempData["Success"]
        </div>
    }

    <!-- Requests List -->
    @if (Model.Any())
    {
        <div class="space-y-3">
            @foreach (var request in Model)
            {
                <div class="bg-white rounded-2xl shadow-sm hover:shadow-md transition-all duration-300 p-5 border border-gray-100">
                    <div class="flex items-start gap-4">
                        <!-- Icon -->
                        <div class="flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center text-xl @request.StatusColorClass">
                            <i class="@request.IconClass"></i>
                        </div>

                        <!-- Content -->
                        <div class="flex-1 min-w-0">
                            <div class="flex items-start justify-between gap-2">
                                <div>
                                    <h3 class="font-semibold text-gray-900">إجازة @request.LeaveTypeName</h3>
                                    @if (!string.IsNullOrEmpty(request.Reason))
                                    {
                                        <p class="text-sm text-gray-600 mt-1">@request.Reason</p>
                                    }
                                </div>
                                <span class="flex-shrink-0 px-3 py-1 rounded-full text-xs font-semibold @request.StatusColorClass">
                                    @request.StatusName
                                </span>
                            </div>
                            <div class="flex items-center gap-4 mt-3 text-xs text-gray-400">
                                <span class="flex items-center gap-1">
                                    <i class="bi bi-clock"></i>
                                    @request.CreatedAt.ToString("yyyy/MM/dd HH:mm")
                                </span>
                                @if (request.RespondedAt.HasValue)
                                {
                                    <span class="flex items-center gap-1">
                                        <i class="bi bi-check-circle"></i>
                                        تم الرد: @request.RespondedAt.Value.ToString("yyyy/MM/dd HH:mm")
                                    </span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(request.ResponseMessage))
                            {
                                <div class="mt-3 p-3 bg-gray-50 rounded-xl text-sm text-gray-600 border border-gray-100">
                                    <span class="font-semibold text-gray-700">رد المسؤول: </span>
                                    @request.ResponseMessage
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="text-center py-16 bg-white rounded-2xl shadow-sm border border-gray-100">
            <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-gray-100 flex items-center justify-center">
                <i class="bi bi-calendar-plus text-4xl text-gray-400"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-600 mb-1">لا توجد طلبات</h3>
            <p class="text-sm text-gray-400 mb-4">لم تقم بتقديم أي طلب إجازة بعد</p>
            <a href="/employee-dashboard/request-vacation" 
               class="inline-flex px-4 py-2 bg-blue-600 text-white text-sm rounded-xl hover:bg-blue-700 transition-all duration-200">
                <i class="bi bi-plus-circle ml-1"></i>
                تقديم طلب إجازة
            </a>
        </div>
    }
</div>