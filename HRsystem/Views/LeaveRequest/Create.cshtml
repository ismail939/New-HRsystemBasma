@model CreateLeaveRequestViewModel
@{
    ViewData["Title"] = "طلب إجازة";
    Layout = "_EmployeeLayout";
}

<div class="max-w-2xl mx-auto p-4 md:p-6" dir="rtl">
    <!-- Header -->
    <div class="mb-6">
        <h1 class="text-2xl md:text-3xl font-bold text-gray-800">طلب إجازة</h1>
        <p class="text-sm text-gray-500 mt-1">تقديم طلب إجازة جديدة</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 p-4 bg-green-50 border border-green-200 rounded-xl text-green-700 text-sm flex items-center gap-2">
            <i class="bi bi-check-circle-fill text-green-500"></i>
            @TempData["Success"]
        </div>
    }

    <!-- Form Card -->
    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-6 md:p-8">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <!-- Leave Type Selection -->
            <div class="mb-6">
                <label class="block text-sm font-semibold text-gray-700 mb-3">نوع الإجازة</label>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                    <!-- Annual Leave -->
                    <label class="relative cursor-pointer">
                        <input type="radio" asp-for="LeaveType" value="@((int)LeaveType.Annual)" class="peer sr-only" />
                        <div class="p-4 rounded-xl border-2 border-gray-200 bg-white peer-checked:border-blue-500 peer-checked:bg-blue-50 peer-checked:shadow-md transition-all duration-200 hover:shadow-md">
                            <div class="flex flex-col items-center text-center">
                                <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center mb-2">
                                    <i class="bi bi-calendar-check text-green-600 text-lg"></i>
                                </div>
                                <span class="font-semibold text-gray-800">إجازة سنوية</span>
                                <span class="text-xs text-gray-500 mt-1">21-30 يوم مدفوعة</span>
                            </div>
                        </div>
                    </label>

                    <!-- Casual Leave -->
                    <label class="relative cursor-pointer">
                        <input type="radio" asp-for="LeaveType" value="@((int)LeaveType.Casual)" class="peer sr-only" />
                        <div class="p-4 rounded-xl border-2 border-gray-200 bg-white peer-checked:border-blue-500 peer-checked:bg-blue-50 peer-checked:shadow-md transition-all duration-200 hover:shadow-md">
                            <div class="flex flex-col items-center text-center">
                                <div class="w-10 h-10 rounded-full bg-yellow-100 flex items-center justify-center mb-2">
                                    <i class="bi bi-sun text-yellow-600 text-lg"></i>
                                </div>
                                <span class="font-semibold text-gray-800">إجازة عارضة</span>
                                <span class="text-xs text-gray-500 mt-1">زواج/وفاة/مولود</span>
                            </div>
                        </div>
                    </label>

                    <!-- Sick Leave -->
                    <label class="relative cursor-pointer">
                        <input type="radio" asp-for="LeaveType" value="@((int)LeaveType.Sick)" class="peer sr-only" />
                        <div class="p-4 rounded-xl border-2 border-gray-200 bg-white peer-checked:border-blue-500 peer-checked:bg-blue-50 peer-checked:shadow-md transition-all duration-200 hover:shadow-md">
                            <div class="flex flex-col items-center text-center">
                                <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center mb-2">
                                    <i class="bi bi-heart-pulse text-red-600 text-lg"></i>
                                </div>
                                <span class="font-semibold text-gray-800">إجازة مرضية</span>
                                <span class="text-xs text-gray-500 mt-1">بشهادة طبية</span>
                            </div>
                        </div>
                    </label>

                    <!-- Hajj Leave -->
                    <label class="relative cursor-pointer">
                        <input type="radio" asp-for="LeaveType" value="@((int)LeaveType.Hajj)" class="peer sr-only" />
                        <div class="p-4 rounded-xl border-2 border-gray-200 bg-white peer-checked:border-blue-500 peer-checked:bg-blue-50 peer-checked:shadow-md transition-all duration-200 hover:shadow-md">
                            <div class="flex flex-col items-center text-center">
                                <div class="w-10 h-10 rounded-full bg-purple-100 flex items-center justify-center mb-2">
                                    <i class="bi bi-building text-purple-600 text-lg"></i>
                                </div>
                                <span class="font-semibold text-gray-800">إجازة حج</span>
                                <span class="text-xs text-gray-500 mt-1">10-15 يوم</span>
                            </div>
                        </div>
                    </label>

                    <!-- Maternity Leave -->
                    <label class="relative cursor-pointer">
                        <input type="radio" asp-for="LeaveType" value="@((int)LeaveType.Maternity)" class="peer sr-only" />
                        <div class="p-4 rounded-xl border-2 border-gray-200 bg-white peer-checked:border-blue-500 peer-checked:bg-blue-50 peer-checked:shadow-md transition-all duration-200 hover:shadow-md">
                            <div class="flex flex-col items-center text-center">
                                <div class="w-10 h-10 rounded-full bg-pink-100 flex items-center justify-center mb-2">
                                    <i class="bi bi-gender-female text-pink-600 text-lg"></i>
                                </div>
                                <span class="font-semibold text-gray-800">إجازة أمومة</span>
                                <span class="text-xs text-gray-500 mt-1">12 أسبوع مدفوعة</span>
                            </div>
                        </div>
                    </label>

                    <!-- Unpaid Leave -->
                    <label class="relative cursor-pointer">
                        <input type="radio" asp-for="LeaveType" value="@((int)LeaveType.Unpaid)" class="peer sr-only" />
                        <div class="p-4 rounded-xl border-2 border-gray-200 bg-white peer-checked:border-blue-500 peer-checked:bg-blue-50 peer-checked:shadow-md transition-all duration-200 hover:shadow-md">
                            <div class="flex flex-col items-center text-center">
                                <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center mb-2">
                                    <i class="bi bi-currency-exchange text-gray-600 text-lg"></i>
                                </div>
                                <span class="font-semibold text-gray-800">بدون راتب</span>
                                <span class="text-xs text-gray-500 mt-1">إجازة غير مدفوعة</span>
                            </div>
                        </div>
                    </label>

                    <!-- Compensatory Leave -->
                    <label class="relative cursor-pointer">
                        <input type="radio" asp-for="LeaveType" value="@((int)LeaveType.Compensatory)" class="peer sr-only" />
                        <div class="p-4 rounded-xl border-2 border-gray-200 bg-white peer-checked:border-blue-500 peer-checked:bg-blue-50 peer-checked:shadow-md transition-all duration-200 hover:shadow-md">
                            <div class="flex flex-col items-center text-center">
                                <div class="w-10 h-10 rounded-full bg-teal-100 flex items-center justify-center mb-2">
                                    <i class="bi bi-arrow-repeat text-teal-600 text-lg"></i>
                                </div>
                                <span class="font-semibold text-gray-800">إجازة تعويضي</span>
                                <span class="text-xs text-gray-500 mt-1">بدل عطلة وطنية</span>
                            </div>
                        </div>
                    </label>

                    <!-- Official Holiday Leave -->
                    <label class="relative cursor-pointer">
                        <input type="radio" asp-for="LeaveType" value="@((int)LeaveType.OfficialHoliday)" class="peer sr-only" />
                        <div class="p-4 rounded-xl border-2 border-gray-200 bg-white peer-checked:border-blue-500 peer-checked:bg-blue-50 peer-checked:shadow-md transition-all duration-200 hover:shadow-md">
                            <div class="flex flex-col items-center text-center">
                                <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center mb-2">
                                    <i class="bi bi-flag text-blue-600 text-lg"></i>
                                </div>
                                <span class="font-semibold text-gray-800">إجازة رسمية</span>
                                <span class="text-xs text-gray-500 mt-1">أعياد/مناسبات</span>
                            </div>
                        </div>
                    </label>

                    <!-- Exam Leave -->
                    <label class="relative cursor-pointer">
                        <input type="radio" asp-for="LeaveType" value="@((int)LeaveType.Exam)" class="peer sr-only" />
                        <div class="p-4 rounded-xl border-2 border-gray-200 bg-white peer-checked:border-blue-500 peer-checked:bg-blue-50 peer-checked:shadow-md transition-all duration-200 hover:shadow-md">
                            <div class="flex flex-col items-center text-center">
                                <div class="w-10 h-10 rounded-full bg-orange-100 flex items-center justify-center mb-2">
                                    <i class="bi bi-book text-orange-600 text-lg"></i>
                                </div>
                                <span class="font-semibold text-gray-800">إجازة اختبارات</span>
                                <span class="text-xs text-gray-500 mt-1">للطلاب الموظفين</span>
                            </div>
                        </div>
                    </label>
                </div>
                <span asp-validation-for="LeaveType" class="text-red-500 text-sm mt-1 block"></span>
            </div>

            <!-- Date Range -->
            <div class="mb-6">
                <label class="block text-sm font-semibold text-gray-700 mb-3">تاريخ الإجازة</label>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label asp-for="StartDate" class="block text-xs text-gray-500 mb-1">من تاريخ</label>
                        <input asp-for="StartDate" type="date" 
                               class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition-all duration-200" />
                        <span asp-validation-for="StartDate" class="text-red-500 text-sm mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="EndDate" class="block text-xs text-gray-500 mb-1">إلى تاريخ</label>
                        <input asp-for="EndDate" type="date" 
                               class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition-all duration-200" />
                        <span asp-validation-for="EndDate" class="text-red-500 text-sm mt-1 block"></span>
                    </div>
                </div>
            </div>

            <!-- Reason -->
            <div class="mb-6">
                <label asp-for="Reason" class="block text-sm font-semibold text-gray-700 mb-2">السبب (اختياري)</label>
                <textarea asp-for="Reason" rows="4" 
                          class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition-all duration-200 resize-none"
                          placeholder="اكتب سبب الإجازة..."></textarea>
                <span asp-validation-for="Reason" class="text-red-500 text-sm mt-1 block"></span>
            </div>

            <!-- Submit -->
            <div class="flex items-center gap-3">
                <button type="submit" 
                        class="px-6 py-3 bg-blue-600 text-white font-semibold rounded-xl hover:bg-blue-700 transition-all duration-200 shadow-md hover:shadow-lg flex items-center gap-2">
                    <i class="bi bi-send"></i>
                    تقديم الطلب
                </button>
                <a href="/employee-dashboard/my-requests" 
                   class="px-6 py-3 bg-gray-100 text-gray-700 font-semibold rounded-xl hover:bg-gray-200 transition-all duration-200">
                    طلباتي
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}