@model NotificationListViewModel
@{
    ViewData["Title"] = "الإشعارات";
    Layout = User.IsInRole("Employee") ? "_EmployeeLayout" : "_Layout";
}

<div class="max-w-4xl mx-auto p-4 md:p-6" dir="rtl">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl md:text-3xl font-bold text-gray-800">الإشعارات</h1>
            <p class="text-sm text-gray-500 mt-1">
                @Model.TotalCount إشعار
                @if (Model.UnreadCount > 0)
                {
                    <span class="text-blue-600 font-semibold">(@Model.UnreadCount غير مقروء)</span>
                }
            </p>
        </div>
        @if (Model.UnreadCount > 0)
        {
            <button id="markAllReadBtn" onclick="markAllAsRead()" 
                    class="px-4 py-2 bg-blue-600 text-white text-sm rounded-xl hover:bg-blue-700 transition-all duration-200 shadow-md hover:shadow-lg flex items-center gap-2">
                <i class="bi bi-check2-all"></i>
                تحديد الكل مقروء
            </button>
        }
    </div>

    <!-- Notifications List -->
    <div class="space-y-3" id="notificationsContainer">
        @if (Model.Notifications.Any())
        {
            @foreach (var notification in Model.Notifications)
            {
                <div id="notification-@notification.NotificationId" 
                     class="notification-card @(notification.IsRead ? "bg-white" : "bg-blue-50/70 border-l-4") rounded-2xl shadow-sm hover:shadow-md transition-all duration-300 p-4 md:p-5 border @(notification.IsRead ? "border-gray-100" : "border-blue-200")">
                    <div class="flex items-start gap-4">
                        <!-- Icon -->
                        <div class="flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center text-xl @notification.BadgeColorClass">
                            <i class="@notification.IconClass"></i>
                        </div>

                        <!-- Content -->
                        <div class="flex-1 min-w-0">
                            <div class="flex items-start justify-between gap-2">
                                <div>
                                    <h3 class="font-semibold text-gray-900 @(notification.IsRead ? "" : "text-base")">
                                        @notification.Title
                                    </h3>
                                    <p class="text-sm text-gray-600 mt-1 line-clamp-2">@notification.Message</p>
                                </div>
                                @if (!notification.IsRead)
                                {
                                    <span class="flex-shrink-0 w-2.5 h-2.5 rounded-full bg-blue-500 mt-2"></span>
                                }
                            </div>
                            <div class="flex items-center gap-3 mt-3 text-xs text-gray-400">
                                <span class="flex items-center gap-1">
                                    <i class="bi bi-clock"></i>
                                    @notification.RelativeTime
                                </span>
                                <span class="flex items-center gap-1">
                                    <i class="bi bi-calendar"></i>
                                    @notification.CreatedAt.ToString("yyyy/MM/dd HH:mm")
                                </span>
                                @if (notification.RelatedRequestId.HasValue)
                                {
                                    <span class="flex items-center gap-1">
                                        <i class="bi bi-link-45deg"></i>
                                        طلب #@notification.RelatedRequestId
                                    </span>
                                }
                            </div>
                            @if (!notification.IsRead)
                            {
                                <button onclick="markAsRead(@notification.NotificationId)" 
                                        class="mt-3 text-xs text-blue-600 hover:text-blue-800 font-medium transition-colors">
                                    <i class="bi bi-check"></i>
                                    تحديد كمقروء
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <!-- Empty State -->
            <div class="text-center py-16 bg-white rounded-2xl shadow-sm border border-gray-100">
                <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-gray-100 flex items-center justify-center">
                    <i class="bi bi-bell-slash text-4xl text-gray-400"></i>
                </div>
                <h3 class="text-lg font-semibold text-gray-600 mb-1">لا توجد إشعارات</h3>
                <p class="text-sm text-gray-400">عندما تصلك إشعارات جديدة، ستظهر هنا</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        async function markAsRead(id) {
            try {
                const response = await fetch(`/notifications/mark-read/${id}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    }
                });
                if (response.ok) {
                    const card = document.getElementById(`notification-${id}`);
                    if (card) {
                        card.classList.remove('bg-blue-50/70', 'border-l-4', 'border-blue-200');
                        card.classList.add('bg-white', 'border-gray-100');
                        const badge = card.querySelector('.w-2\\.5');
                        if (badge) badge.remove();
                        const btn = card.querySelector('button');
                        if (btn) btn.remove();
                    }
                    location.reload();
                }
            } catch (e) {
                console.error('Failed to mark as read:', e);
            }
        }

        async function markAllAsRead() {
            try {
                const response = await fetch('/notifications/mark-all-read', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    }
                });
                if (response.ok) {
                    location.reload();
                }
            } catch (e) {
                console.error('Failed to mark all as read:', e);
            }
        }
    </script>
}