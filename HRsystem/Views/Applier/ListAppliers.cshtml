@model IEnumerable<HRsystem.Models.HRApplier>;

@{
    ViewData["Title"] = "المتقدمون";
}

<div class="flex flex-row flex-start gap-2 mb-1">

    <div class="flex flex-row justify-start">
        <a href="/appliers/add" id="createBtn" class="col-button-dark px-4 py-2 rounded mb-2">
            إضافة المتقدمون
        </a>
    </div>
    <div x-data="{
        showSearch: false,
        toggleSearch() {
            this.showSearch = !this.showSearch;

            if (this.showSearch) {
                // Focus the input after it appears
                this.$nextTick(() => document.getElementById('searchInput')?.focus());
            } else {
                // Clear and show all employees when refresh is clicked
                const input = document.getElementById('searchInput');
                if (input) input.value = '';
                showAllEmployees();
            }
        }
    }" class="flex items-center gap-2">
        <!-- Search / Refresh Button -->
        <button @@click="toggleSearch"
            class="p-2 rounded-full bg-[#404E3B] text-white hover:bg-[#A7B89A] transition-all duration-300">
            <i :class="showSearch ? 'bi-arrow-clockwise' : 'bi-search'" class="text-lg"></i>
        </button>

        <!-- Search input -->
        <template x-if="showSearch">
            <div class="flex items-center gap-2 animate-fade-in">
                <input id="searchInput" type="text" placeholder="ابحث عن المتقدمون..." oninput="searchForApplier()"
                    class="border border-gray-300 rounded-md px-5 py-2 focus:ring focus:ring-[#BAC8B1] focus:outline-none text-sm" />
            </div>
        </template>
    </div>

</div>


<div id="tableResponsive" class="overflow-y-auto max-h-[500px] rounded-lg shadow-md ">
    <table class="table-base min-w-full border-separate border-spacing-0">
        <thead class="table-dark col-table-header sticky top-0 z-10">
            <tr>
                <th>الاسم</th>
                <th>الرقم القومي</th>
                <th>رقم الهاتف</th>
                <th>الحالة الاجتماعية</th>
                <th>الديانة</th>
                <th>تاريخ الميلاد</th>
                <th>رقم التأمين</th>
                <th>تاريخ التعيين</th>
                <th>تاريخ الانتهاء</th>
                <th>القسم</th>
                <th>المسمى الوظيفي</th>
                <th>نوع العقد</th>
                <th>تعديل بيانات</th>
            </tr>
        </thead>
    
    </table>
</div>


<!-- Modal Background -->
<div id="createModal" class="fixed inset-0 bg-black bg-opacity-50 hidden justify-center items-center z-50
            transition-all duration-300 ease-out opacity-0 scale-95">
    <!-- Modal Box -->
    <div class="col-modal w-full md:w-11/12 h-full md:h-[90%] p-6 relative" dir="rtl">
        <!-- Close Button -->
        <button onclick="closeModalCreate()" class="absolute top-3 left-3 text-gray-500 hover:text-gray-700 text-xl">
            ✕
        </button>
        @* 
        <!-- Tabs -->
        <div class="flex border-b mb-4">
           
        </div> *@

        <h2 class="text-2xl font-semibold mb-4 text-blue-700 text-center">إضافة المتقدمون جديد</h2>
        <form id="employeeFormCreate" method="post"
            class="grid grid-cols-1 md:grid-cols-3 gap-x-4 gap-y-1 w-full h-full">

            <input type="hidden" name="Id" />

            <div>
                <label class="block text-sm font-medium text-gray-700">الاسم</label>
                <input type="text" name="Name"
                    class="mt-1 w-full border rounded p-2 focus:outline-none focus:ring focus:ring-[#7B9669]" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700">الرقم القومي</label>
                <input type="text" name="NationalId"
                    class="mt-1 w-full border rounded p-2 focus:outline-none focus:ring focus:ring-[#7B9669]" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700">رقم الهاتف</label>
                <input type="tel" name="PhoneNumber"
                    class="mt-1 w-full border rounded p-2 focus:outline-none focus:ring focus:ring-[#7B9669]" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700">الحالة الاجتماعية</label>
                <input type="text" name="MarriageStatus"
                    class="mt-1 w-full border rounded p-2 focus:outline-none focus:ring focus:ring-[#7B9669]" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700">الديانة</label>
                <input type="text" name="Religion"
                    class="mt-1 w-full border rounded p-2 focus:outline-none focus:ring focus:ring-[#7B9669]" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700">تاريخ الميلاد</label>
                <input type="date" name="DateOfBirth"
                    class="mt-1 w-full border rounded p-2 focus:outline-none focus:ring focus:ring-[#7B9669]" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700">رقم التأمين</label>
                <input type="text" name="InsuranceNumber"
                    class="mt-1 w-full border rounded p-2 focus:outline-none focus:ring focus:ring-[#7B9669]" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700">تاريخ التعيين</label>
                <input type="date" name="HireDate"
                    class="mt-1 w-full border rounded p-2 focus:outline-none focus:ring focus:ring-[#7B9669]" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700">تاريخ الانتهاء</label>
                <input type="date" name="EndDate"
                    class="mt-1 w-full border rounded p-2 focus:outline-none focus:ring focus:ring-[#7B9669]" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700">القسم</label>
                <input type="text" name="Department"
                    class="mt-1 w-full border rounded p-2 focus:outline-none focus:ring focus:ring-[#7B9669]" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700">المسمى الوظيفي</label>
                <input type="text" name="JobName"
                    class="mt-1 w-full border rounded p-2 focus:outline-none focus:ring focus:ring-[#7B9669]" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700">نوع العقد</label>
                <input type="text" name="ContractType"
                    class="mt-1 w-full border rounded p-2 focus:outline-none focus:ring focus:ring-[#7B9669]" />
            </div>

            <div class="mt-0 bg-gray-200 col-span-3 rounded-2xl p-2">
                <div class="upload-container w-full">
                    <label for="fileUploadCreate" class="upload-label">📤 رفع ملف جديد</label>
                    <input type="file" id="fileUploadCreate" class="upload-input" name="imageFiles" multiple />
                </div>

            </div>
            <!-- Submit Button -->
            <div class="col-span-3 text-center m-4">
                <button type="submit" class="px-8 py-2 rounded col-button-dark">
                    💾 حفظ
                </button>
                @* <button class="bg-gray-600 text-white px-8 py-2 rounded hover:bg-gray-300 transition">
                            الملفات
                        </button> *@

            </div>

        </form>



    </div>
</div>


<!-- Modal Background -->
<div id="editModal" class="fixed inset-0 bg-black bg-opacity-50 hidden justify-center items-center z-50
            transition-all duration-300 ease-out opacity-0 scale-95">
    <!-- Modal Box -->
    <div class="col-modal w-full md:w-11/12 h-full md:h-[90%] p-6 relative overflow-y-auto" dir="rtl">
        <!-- Close Button -->
        <button onclick="closeModal()" class="absolute top-3 left-3 text-gray-500 hover:text-gray-700 text-xl">
            ✕
        </button>

        <!-- Tabs -->
        <div class="flex border-b mb-4">
            <button id="tab-info"
