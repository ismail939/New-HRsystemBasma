                const files = await res.json();
                console.log('Fetched files:');
                console.log(files);

                if (files.length === 0) {
                    filesList.innerHTML = "<p class='text-gray-500'>لا توجد ملفات لهذا الموظف.</p>";
                } else {
                    filesList.innerHTML = files.map(file => `
