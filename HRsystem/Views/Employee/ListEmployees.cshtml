        </div>
        <div id="tab-content-files" class="hidden">
            <!-- Employee files -->
            <div class="space-y-3">
                <h3 class="font-semibold text-gray-700">📎 ملفات الموظف</h3>
                <button class="col-button-light" onclick="downloadAllFiles()">تنزيل الملفات مجمعة</button>
                <ul class="flex flex-row flex-wrap gap-10">

                </ul>
                <div class="mt-4 bg-gray-200 w-full rounded-2xl p-2">
                    <div class="upload-container w-full">
                        <form id="uploadFileForm" enctype="multipart/form-data">
                            <input type="hidden" name="EmployeeId" />
                            <label for="fileUpload" class="upload-label">📤 رفع ملف جديد</label>
                            <input type="file" id="fileUpload" class="upload-input" name="imageFiles" multiple />
