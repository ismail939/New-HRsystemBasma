</div>

<!-- ✅ The lightbox -->
<div id="imageLightbox"
    class="fixed inset-0 w-full h-full bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <img id="lightboxImage"
        class="max-w-3xl max-h-[90vh] rounded-2xl shadow-2xl transition-transform duration-300 scale-95" />
</div>

@section Scripts {

    <!-- Modal Script -->
    <script src="~/js/ListEmployees/General.js"></script>
    <script src="~/js/ListEmployees/Create.js"></script>
    <script src="~/js/ListEmployees/Edit.js"></script>
    <script src="~/js/ListEmployees/Shift.js"></script>
    <script src="~/js/ListEmployees/Rate.js"></script>




    <script>
        var employees = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));// from Razor
        const observer = new MutationObserver(mutations => {
            mutations.forEach(m => {
                if (m.attributeName === "class") {
                    console.log(
                        "⚠️ Modal class changed:",
                        modal.className,
                        "at",
                        new Date().toLocaleTimeString(),
                        new Error().stack
                    );
                }
            });
        });

        observer.observe(modal, { attributes: true });
    </script>

}