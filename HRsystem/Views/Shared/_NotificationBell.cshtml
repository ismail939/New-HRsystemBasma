@inject HRsystem.Services.INotificationService _notificationService
@using System.Security.Claims
@{
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    int unreadCount = 0;
    if (!string.IsNullOrEmpty(userId) && int.TryParse(userId, out var uid))
    {
        unreadCount = await _notificationService.GetUnreadCount(uid);
    }
}

<div class="relative" x-data="notificationBell()" x-init="init()">
    <!-- Bell Icon -->
    <button @@click="toggleDropdown()" class="relative p-2 rounded-full hover:bg-white/10 transition-all duration-200 focus:outline-none group">
        <i class="bi bi-bell-fill text-white text-xl md:text-2xl group-hover:scale-110 transition-transform duration-200"></i>
        
        <!-- Notification Badge -->
        <div x-show="unreadCount > 0"
             x-cloak
             class="absolute -top-1 -right-1 min-w-[20px] h-5 flex items-center justify-center rounded-full bg-red-500 text-white text-[10px] font-bold shadow-lg border-2 border-white animate-badge-in">
            <span x-text="unreadCount > 99 ? '99+' : unreadCount"></span>
        </div>
    </button>

    <!-- Dropdown -->
    <div x-show="isOpen"
         x-cloak
         @@click.outside="closeDropdown()"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 -translate-y-2 scale-95"
         x-transition:enter-end="opacity-100 translate-y-0 scale-100"
         class="absolute left-1/2 -translate-x-1/2 rtl:translate-x-1/2 mt-2 w-80 md:w-96 bg-white rounded-2xl shadow-2xl border border-gray-100 z-[9999] overflow-hidden"
         style="transform-origin: top center;">

        <!-- Dropdown Header -->
        <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between" style="background: linear-gradient(to left, #f8faf8, #ffffff);">
            <h3 class="font-bold text-sm" style="color: #404E3B;">الإشعارات</h3>
            <button @@click="markAllRead()" x-show="unreadCount > 0" class="text-xs font-medium hover:underline transition-colors" style="color: #7B9669;">
                تحديد الكل كمقروء
            </button>
        </div>

        <!-- Notifications List -->
        <div class="max-h-[400px] overflow-y-auto divide-y divide-gray-50">
            <template x-for="notification in notifications" :key="notification.NotificationId">
                <a :href="notification.NavigateUrl || '/Notifications'"
                   @@click="markRead(notification)"
                   :class="{'bg-green-50/40': !notification.IsRead, 'hover:bg-gray-50': true}"
                   class="flex items-start gap-3 px-4 py-3 cursor-pointer transition-all duration-200 border-r-4 no-underline"
                   :style="'border-right-color: ' + getBorderColor(notification.NotificationType)">
                    
                    <!-- Icon -->
                    <div class="flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center text-base"
                         :class="getIconBg(notification.NotificationType)">
                        <i :class="getIcon(notification.NotificationType)"></i>
                    </div>

                    <!-- Content -->
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-semibold truncate" :class="notification.IsRead ? 'text-gray-700' : 'text-gray-900'" x-text="notification.Title"></p>
                        <p class="text-xs mt-0.5 line-clamp-2" style="color: #6C8480;" x-text="notification.Message"></p>
                        <p class="text-[10px] mt-1" style="color: #6C8480;" x-text="notification.RelativeTime"></p>
                    </div>

                    <!-- Unread Indicator -->
                    <div x-show="!notification.IsRead" class="flex-shrink-0 mt-1">
                        <div class="w-2 h-2 rounded-full" style="background-color: #7B9669;"></div>
                    </div>
                </a>
            </template>

            <!-- Empty State -->
            <div x-show="notifications.length === 0" class="py-8 text-center" style="color: #6C8480;">
                <i class="bi bi-bell-slash text-3xl block mb-2"></i>
                <p class="text-sm">لا توجد إشعارات</p>
            </div>
        </div>

        <!-- Footer -->
        <a href="/Notifications"
           class="block px-4 py-3 text-center text-sm font-semibold transition-colors border-t border-gray-100" style="color: #7B9669; hover:color: #404E3B;">
            عرض كل الإشعارات
            <i class="bi bi-arrow-left mr-1"></i>
        </a>
    </div>
</div>

<style>
    [x-cloak] { display: none !important; }
    @@keyframes badgeIn {
        0% { transform: scale(0); opacity: 0; }
        50% { transform: scale(1.3); }
        100% { transform: scale(1); opacity: 1; }
    }
    .animate-badge-in {
        animation: badgeIn 0.4s ease-out;
    }
</style>

<script>
    function notificationBell() {
        return {
            isOpen: false,
            unreadCount: @unreadCount,
            notifications: [],
            pollingInterval: null,

            init() {
                this.fetchNotifications();
                this.pollingInterval = setInterval(() => this.fetchUnreadCount(), 60000);
            },

            async fetchNotifications() {
                try {
                    const response = await fetch('/notifications/recent');
                    const data = await response.json();
                    this.notifications = data.Notifications || [];
                    this.unreadCount = data.UnreadCount || 0;
                } catch (e) {
                    console.error('Failed to fetch notifications:', e);
                }
            },

            async fetchUnreadCount() {
                try {
                    const response = await fetch('/notifications/unread-count');
                    const data = await response.json();
                    if (data && typeof data.count !== 'undefined') {
                        this.unreadCount = data.count;
                    }
                } catch (e) {
                    console.error('Failed to fetch unread count:', e);
                }
            },

            toggleDropdown() {
                this.isOpen = !this.isOpen;
                if (this.isOpen) {
                    this.fetchNotifications();
                }
            },

            closeDropdown() {
                this.isOpen = false;
            },

            async markRead(notification) {
                if (!notification.IsRead) {
                    try {
                        await fetch(`/notifications/mark-read/${notification.NotificationId}`, { method: 'POST' });
                        notification.IsRead = true;
                        this.unreadCount = Math.max(0, this.unreadCount - 1);
                    } catch (e) {
                        console.error('Failed to mark as read:', e);
                    }
                }
            },

            async markAllRead() {
                try {
                    await fetch('/notifications/mark-all-read', { method: 'POST' });
                    this.notifications.forEach(n => n.IsRead = true);
                    this.unreadCount = 0;
                } catch (e) {
                    console.error('Failed to mark all as read:', e);
                }
            },

            getIcon(type) {
                const icons = {
                    1: 'bi bi-calendar-plus',
                    2: 'bi bi-check-circle',
                    3: 'bi bi-x-circle',
                    4: 'bi bi-clock',
                    5: 'bi bi-person-x',
                    6: 'bi bi-person-dash',
                    7: 'bi bi-building-add',
                    100: 'bi bi-bell'
                };
                return icons[type] || 'bi bi-bell';
            },

            getIconBg(type) {
                const bgs = {
                    1: 'bg-blue-100 text-blue-600',
                    2: 'bg-green-100 text-green-600',
                    3: 'bg-red-100 text-red-600',
                    4: 'bg-yellow-100 text-yellow-600',
                    5: 'bg-orange-100 text-orange-600',
                    6: 'bg-red-100 text-red-600',
                    7: 'bg-purple-100 text-purple-600',
                    100: 'bg-gray-100 text-gray-600'
                };
                return bgs[type] || 'bg-gray-100 text-gray-600';
            },

            getBorderColor(type) {
                const colors = {
                    1: '#7B9669',
                    2: '#404E3B',
                    3: '#DC2626',
                    4: '#F59E0B',
                    5: '#F97316',
                    6: '#DC2626',
                    7: '#7B9669',
                    100: '#6C8480'
                };
                return colors[type] || '#6C8480';
            }
        }
    }
</script>