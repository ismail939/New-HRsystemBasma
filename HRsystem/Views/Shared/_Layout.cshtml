@{
    @* var currentController = Context.Request.RouteValues["controller"]?.ToString(); *@
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    Console.WriteLine("Current Controller: 🟢" + currentController);
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" />
    <link href="~/css/output.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/HRsystem.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/themes.css" asp-append-version="true" />
    <link rel="icon" href="~/images/logo2.png" sizes="96x96" type="image/png">
    </head>

    <script>
        (function () {
            var STORAGE_KEY = 'hr-theme';
            var DEFAULT_THEME = 'light';

            function getSystemTheme() {
                if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
                    return 'dark';
                }
                return DEFAULT_THEME;
            }

            function getStoredTheme() {
                try {
                    var stored = localStorage.getItem(STORAGE_KEY);
                    if (stored === 'light' || stored === 'dark') return stored;
                } catch (e) { }
                return getSystemTheme();
            }

            var theme = getStoredTheme();
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>
    <body id="" class="h-full w-full min-h-screen bg-color1">



        <div class="flex flex-row min-h-screen ">

            <nav class="w-full h-16 col-nav text-white flex fixed top-0 inset-x-0 z-40">

                <div class="w-full flex flex-row items-center justify-start h-full">

                    <!-- Logo -->
                    <div class="flex items-center border-l-2 border-white h-full pl-16 me-4 shrink-0">
                        <img src="/images/logo2.png" class="w-12 h-12" />                        
                        <span class="font-bold px-2 whitespace-nowrap">الموارد البشرية</span>
                    </div>

                    <!-- Desktop Menu -->
                    <ul class="hidden min-[1100px]:flex flex-row gap-1 flex-1 mx-4 h-full">
                            <li><a href="/employees"
                                       class="nav-link  @(currentController == "Employee" ? "active" : "")">الموظفين</a></li>
                                <li><a href="/basma" class="nav-link  @(currentController == "Basma" ? "active" : "")">البصمة</a>
                                </li>
                                <li><a href="/OffDays" class="nav-link  @(currentController == "OffDay" ? "active" : "")">الاجازات
                                </a></li>
                                <li><a href="/penalties"
                                           class="nav-link  @(currentController == "Penalty" ? "active" : "")">الجزاءات</a></li>
                                    <li><a href="/payroll/salary-components"
                                               class="nav-link  @(currentController == "Payroll" ? "active" : "")">الرواتب</a></li>
                                    <li class="relative" id="moreDropdown">
                                        <a href="javascript:void(0)" onclick="toggleDropdown()" class="nav-link flex items-center gap-1">
                                            المزيد <i id="moreArrow" class="bi bi-chevron-down text-[12px]"></i>
                                        </a>
                                        <div id="moreMenu" class="absolute top-full right-0 mt-0 bg-color2 rounded-b-lg shadow-xl z-50 min-w-[160px] hidden">
                                            <a href="/reports" class="block !text-white px-6 py-3 hover:bg-color3 transition-colors text-right rounded-t-lg @(currentController == "Report" ? "bg-color3" : "")">التقارير</a>
                                            @if (User.IsInRole("HR") || User.IsInRole("Admin"))
                                            {
                                                <a href="/requests/pending" class="block !text-white px-6 py-3 hover:bg-color3 transition-colors text-right @(currentController == "Request" ? "bg-color3" : "")">الطلبات</a>
                                            }
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <a href="/admin/dashboard" class="block !text-white px-6 py-3 hover:bg-color3 transition-colors text-right rounded-b-lg">الإدارة</a>
                                            }
                                        </div>
                                    </li>
                                    </ul>

                                    <!-- Right Side Info -->
                                    <div class="hidden min-[1100px]:flex items-center gap-2 ms-auto me-4">
                                        <!-- Notification Bell -->
                                        @if (User.Identity?.IsAuthenticated == true)
                                        {
                                            @await Html.PartialAsync("_NotificationBell")
                                        }

                                        <div class="bg-color1 text-color5 font-semibold px-3 py-1.5 rounded-lg whitespace-nowrap">
                                            @User.Identity?.Name
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <span class="text-sm text-color3"> (Admin) </span>
                                            }
                                        </div>

                                        @if (User.Identity?.IsAuthenticated == true)
                                        {
                                            <button id="themeToggle" class="ms-2 text-xl px-2 py-1 rounded-lg border border-white/30 hover:bg-white/10 transition" title="تبديل المظهر">
                                                <i id="themeIcon" class="bi bi-brightness-high-fill"></i>
                                            </button>
                                        }

                                        <form method="post" action="/logout" class="ms-1">
                                            @Html.AntiForgeryToken()
                                            <button class="col-button-dark px-3 py-1.5 text-[12px] whitespace-nowrap">
                                                <i class="bi bi-box-arrow-right me-1"></i>
                                                تسجيل الخروج
                                            </button>
                                        </form>
                                    </div>

                                    <!-- Hamburger Button -->
                                    <button onclick="toggleMenu()" class="min-[1100px]:hidden block text-2xl me-2 ms-auto">
                                        ☰
                                    </button>

                                </div>



                            </nav>
                            <!-- Mobile Side Panel -->
                            <div id="mobileMenu"
                                 class="fixed top-0 right-0 h-full w-64 !bg-color1 text-color3 transform translate-x-full transition-transform duration-100 z-50 shadow-lg ">
                                <div class="p-4 flex justify-between items-center border-b border-color3">
                                    <span class="font-bold">القائمة</span>
                                    <button onclick="toggleMenu()" class="text-[25px]">
                                        <i class="bi bi-x-square-fill"></i>
                                    </button>
                                </div>
                                <div class="flex justify-center w-full">
                                    <img src="/images/logo2.png" class="w-32 h-32 self-center" />
                                </div>
                                <div class="text-center mt-3">اسم المستخدم</div>

                                <div class="bg-color1 text-color5 font-bold m-2 text-center border-2 border-color3 p-2 rounded-lg">
                                    @User.Identity?.Name
                                </div> 
                                <ul class="flex flex-col gap-1 p-4 !text-color3 !bg-color1 border-y text-center border-color3">

                                    @* <li><a href="/dashboard" class="!font-bold  @(currentController == "Home" ? "active-mobile" : "nav-mobile-link")">تقرير
                            اليوم</a></li> *@
                            <li><a href="/employees"
                                       class="!font-bold   @(currentController == "Employee" ? "active-mobile" : "nav-mobile-link")">الموظفين</a></li>
                                <li><a href="/basma" class="!font-bold   @(currentController == "Basma" ? "active-mobile" : "nav-mobile-link")">البصمة</a>
                                </li>
                                <li><a href="/OffDays" class="!font-bold   @(currentController == "OffDay" ? "active-mobile" : "nav-mobile-link")">الاجازات
                                </a></li>
                                <li><a href="/penalties"
                                           class="!font-bold   @(currentController == "Penalty" ? "active-mobile" : "nav-mobile-link")">الجزاءات</a></li>
                                    <li><a href="/payroll/salary-components"
                                               class="!font-bold   @(currentController == "Payroll" ? "active-mobile" : "nav-mobile-link")">الرواتب</a></li>
                                    <li><a href="/reports"
                                               class="!font-bold   @(currentController == "Report" ? "active-mobile" : "nav-mobile-link")">التقارير</a></li>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <li><a href="/admin/dashboard" class="!font-bold  @(currentController == "Admin" ? "active-mobile" : "nav-mobile-link")">الادمن</a></li>
                                        }




                                    <li>
                                        <form method="post" action="/logout">
                                            @Html.AntiForgeryToken()
                                            <button class="col-button-dark mt-2 w-full p-2">
                                                تسجيل الخروج
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                            <div id="overlay" onclick="toggleMenu()" class="fixed inset-0 bg-black/50 hidden z-40"></div>
                            <!-- Main Content -->
                            <div class="flex !p-2 w-full transition-all duration-700 mt-16 " id="main-content">

                                @* <!-- زر فتح/إغلاق الـ sidebar -->
            <button class="bg-blue-600 text-white px-4 py-2 rounded mb-4" onclick="toggleSidebar()">
                ☰ القائمة
            </button> *@

                                <main role="main" class="pb-3 w-full h-full">
                                    <div id="loadingOverlay" class="loading-overlay hidden">
                                        <div class="spinner"></div>
                                    </div>

                                    @RenderBody()
                                </main>
                            </div>
                        </div>
                        <script>
                                            function toggleMenu() {
                                                const menu = document.getElementById("mobileMenu");
                                                const overlay = document.getElementById("overlay");
                                                menu.classList.toggle("translate-x-full");
                                                overlay.classList.toggle("hidden");

                                                document.body.classList.toggle("overflow-hidden"); // 🔥 important
                                        }

                                        function toggleDropdown() {
                                            const menu = document.getElementById("moreMenu");
                                            const arrow = document.getElementById("moreArrow");
                                            const isOpen = !menu.classList.contains("hidden");
                                            menu.classList.toggle("hidden");
                                            if (arrow) {
                                                arrow.style.transform = isOpen ? "rotate(0deg)" : "rotate(180deg)";
                                            }
                                        }

                                        document.addEventListener("click", function(e) {
                                            const dropdown = document.getElementById("moreDropdown");
                                            const menu = document.getElementById("moreMenu");
                                            if (dropdown && menu && !dropdown.contains(e.target)) {
                                                menu.classList.add("hidden");
                                                const arrow = document.getElementById("moreArrow");
                                                if (arrow) arrow.style.transform = "rotate(0deg)";
                                            }
                                        });
                        </script>
                        <script src="~/lib/jquery/dist/jquery.min.js"></script>
                        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
                        <script src="~/js/theme.js" asp-append-version="true"></script>
                        <script src="~/js/site.js" asp-append-version="true"></script>
                        <link href="~/lib/flatpickr/dist/flatpickr.min.css" rel="stylesheet" />
                        <script src="~/lib/flatpickr/dist/flatpickr.min.js"></script>
                        <script src="~/lib/flatpickr/dist/l10n/ar.js"></script>
                        <script src="~/lib/alpinejs/dist/cdn.min.js" defer></script>
                        <script src="~/js/apply-select-styles.js" asp-append-version="true"></script>
                        <script>
                            (function () {
                                const btn = document.getElementById("themeToggle");
                                if (btn) {
                                    btn.addEventListener("click", function () {
                                        window.HRTheme.toggle();
                                    });
                                }
                            })();
                        </script>
                        @await RenderSectionAsync("Scripts", required: false)
                    </body>

                </html>