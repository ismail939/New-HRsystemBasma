@model LoginViewModel

@{
    ViewData["Title"] = "الموارد البشرية";
    Layout = "";
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <title>@ViewData["Title"]</title>
    <link href="~/css/output.css" rel="stylesheet" />
    <link rel="icon" href="~/images/logo2.png" sizes="96x96" type="image/png">

</head>

<body class="index_body">

    <div class="group relative rounded-3xl p-6 w-1/2 h-5/6
         flex flex-col items-center justify-center gap-6
         bg-white/30 backdrop-blur-md
         shadow-black/10
         hover:bg-white/40 hover:shadow-2xl
         transition-all duration-500">

        <!-- Logo -->
        <img src="/images/logo2.png" class="w-[200px] h-[200px] object-contain
           group-hover:scale-105 transition-transform duration-300" alt="logo">

        <!-- Title -->
        <p class="text-xl font-semibold text-gray-800 tracking-wide">
            إدارة الموارد البشرية
        </p>

        <form asp-action="Login" method="post" class="gap-3 w-full flex flex-col justify-center items-center">

            <!-- Role Selector -->
            <div class="w-full flex flex-col md:flex-row justify-center gap-3 px-4" role="radiogroup" aria-label="اختيار الدور">

                <!-- HR Card -->
                <div class="role-card flex-1 flex flex-col items-center gap-2 p-4 rounded-xl border-2 border-gray-200
                            bg-white cursor-pointer select-none transition-all duration-300
                            hover:border-color2/40 hover:shadow-md hover:bg-color1/20"
                     role="radio" aria-checked="false" aria-label="الموارد البشرية" tabindex="0"
                     data-role="HR">
                    <span class="text-3xl">👨‍💼</span>
                    <span class="text-sm font-medium text-gray-700">HR</span>
                    <span class="text-xs text-gray-400">الموارد البشرية</span>
                    <div class="check-indicator mt-1 w-5 h-5 rounded-full border-2 border-gray-300
                                flex items-center justify-center transition-all duration-300">
                        <svg class="w-3 h-3 text-white opacity-0 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                    </div>
                </div>

                <!-- Admin Card -->
                <div class="role-card flex-1 flex flex-col items-center gap-2 p-4 rounded-xl border-2 border-gray-200
                            bg-white cursor-pointer select-none transition-all duration-300
                            hover:border-color2/40 hover:shadow-md hover:bg-color1/20"
                     role="radio" aria-checked="false" aria-label="المشرف" tabindex="0"
                     data-role="Admin">
                    <span class="text-3xl">🛡️</span>
                    <span class="text-sm font-medium text-gray-700">Admin</span>
                    <span class="text-xs text-gray-400">المشرف</span>
                    <div class="check-indicator mt-1 w-5 h-5 rounded-full border-2 border-gray-300
                                flex items-center justify-center transition-all duration-300">
                        <svg class="w-3 h-3 text-white opacity-0 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                    </div>
                </div>

                <!-- Employee Card (selected by default) -->
                <div class="role-card flex-1 flex flex-col items-center gap-2 p-4 rounded-xl border-2 border-color3
                            bg-color1/30 cursor-pointer select-none transition-all duration-300 scale-[1.03]
                            hover:border-color3 hover:shadow-md hover:bg-color1/40"
                     role="radio" aria-checked="true" aria-label="الموظف" tabindex="0"
                     data-role="Employee">
                    <span class="text-3xl">👤</span>
                    <span class="text-sm font-medium text-gray-700">Employee</span>
                    <span class="text-xs text-gray-400">الموظف</span>
                    <div class="check-indicator mt-1 w-5 h-5 rounded-full border-2 border-color3 bg-color3
                                flex items-center justify-center transition-all duration-300">
                        <svg class="w-3 h-3 text-white opacity-100 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                    </div>
                </div>

            </div>

            <input type="hidden" id="SelectedRole" name="SelectedRole" value="Employee" />

            <div class="w-full flex justify-center flex-col">
                <label class="block text-sm font-medium self-center mb-1">اسم المستخدم</label>
                <input asp-for="Username" class="text-center w-full border rounded p-2 focus:outline-none focus:ring focus:ring-[#7B9669]"
                    placeholder="اسم المستخدم" />
                <span asp-validation-for="Username" class="text-red-500 text-sm text-center"></span>
            </div>

            <div class="w-full flex justify-center flex-col">
                <label class="block text-sm self-center font-medium mb-1">كلمة المرور</label>
                <input asp-for="Password" type="password"
                    class="w-full border rounded p-2 text-center focus:outline-none focus:ring focus:ring-[#7B9669]" placeholder="كلمة المرور" />
                <span asp-validation-for="Password" class="text-red-500 text-sm text-center"></span>
            </div>

            <!-- Validation Summary -->
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm text-center list-none"></div>

            <!-- Button -->
            <button type="submit" class="cursor-pointer mt-1 inline-flex items-center gap-2
           bg-color3 text-white
           px-8 py-3 rounded-full
           shadow-md shadow-color3/40
           hover:bg-color2 hover:shadow-lg
           hover:-translate-y-1
           transition-all duration-300">

                الدخول
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
            </button>
        </form>

    </div>

</body>

</html>

<script>
    (function () {
        var cards = document.querySelectorAll('.role-card');
        var hiddenInput = document.getElementById('SelectedRole');

        function deselectAll() {
            cards.forEach(function (c) {
                c.classList.remove('border-color3', 'bg-color1/30', 'scale-[1.03]');
                c.classList.add('border-gray-200', 'bg-white');
                c.setAttribute('aria-checked', 'false');

                var indicator = c.querySelector('.check-indicator');
                indicator.classList.remove('border-color3', 'bg-color3');
                indicator.classList.add('border-gray-300', 'bg-transparent');

                var check = indicator.querySelector('svg');
                check.classList.remove('opacity-100');
                check.classList.add('opacity-0');
            });
        }

        function selectCard(card) {
            deselectAll();

            card.classList.remove('border-gray-200', 'bg-white');
            card.classList.add('border-color3', 'bg-color1/30', 'scale-[1.03]');
            card.setAttribute('aria-checked', 'true');

            var indicator = card.querySelector('.check-indicator');
            indicator.classList.remove('border-gray-300', 'bg-transparent');
            indicator.classList.add('border-color3', 'bg-color3');

            var check = indicator.querySelector('svg');
            check.classList.remove('opacity-0');
            check.classList.add('opacity-100');

            hiddenInput.value = card.getAttribute('data-role');
        }

        cards.forEach(function (card) {
            card.addEventListener('click', function () {
                selectCard(card);
            });

            card.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    selectCard(card);
                }
            });
        });
    })();
</script>